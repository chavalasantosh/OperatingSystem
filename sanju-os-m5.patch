+fn write_hex_u64(console: &mut dyn Console, value: u64) {
+    for shift in (0..16).rev() {
+        let nibble = u8::try_from((value >> (shift * 4)) & 0x0f).unwrap_or(0);
+        console.write_byte(if nibble < 10 {
+            b'0' + nibble
+        } else {
+            b'a' + nibble - 10
+        });
+    }
+}
