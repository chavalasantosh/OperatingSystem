+        exit_code,
+        faulted,
+        fault_address: USER_FAULT_ADDRESS.load(Ordering::SeqCst),
+        fault_error_code: USER_FAULT_ERROR.load(Ordering::SeqCst),
+        syscalls: USER_SYSCALLS.load(Ordering::SeqCst),
+        yields: USER_YIELDS.load(Ordering::SeqCst),
