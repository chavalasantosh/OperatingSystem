+#[allow(clippy::cast_ptr_alignment)]
+unsafe fn mark_user_page(address: u64, executable: bool) -> bool {
+    const PRESENT: u64 = 1 << 0;
+    const USER: u64 = 1 << 2;
+    const HUGE: u64 = 1 << 7;
+    const NX: u64 = 1 << 63;
+    const ADDRESS_MASK: u64 = 0x000f_ffff_ffff_f000;
+
