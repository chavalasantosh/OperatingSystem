new file mode 100644
index 0000000..eeddf3d
--- /dev/null
+++ b/user/programs/src/fault-test.S
@@ -0,0 +1,18 @@
+.intel_syntax noprefix
+.section .text
+.global _start
+_start:
+    mov rax, 0
+    lea rdi, [rip + message]
+    mov rsi, 43
+    syscall
+    movabs rbx, 0x0000600000000000
+    mov rax, qword ptr [rbx]
+    mov rax, 2
+    xor rdi, rdi
+    syscall
+    ud2
+.section .rodata
+message:
+    .ascii "fault-test: requesting isolated page fault\n"
+.set message_len, . - message
